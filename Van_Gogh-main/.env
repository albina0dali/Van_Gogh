# Environment Configuration for Subsidy Scoring System
# Copy this file to .env and fill in with your actual values

# ==================== API Settings ====================
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=False
API_LOG_LEVEL=INFO

# ==================== Database Settings ====================
# Supported: sqlite, postgresql
DB_TYPE=sqlite
DB_PATH=subsidy_scoring.db

# PostgreSQL connection (if DB_TYPE=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=subsidy_db

# ==================== Model Settings ====================
MODEL_PATH=models/best_model.pkl
MODEL_VERSION=1.0.0
MODEL_THRESHOLD_APPROVED=0.7
MODEL_THRESHOLD_REJECTED=0.4

# ==================== Security Settings ====================
GROQ_API_KEY=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
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ==================== Feature Settings ====================
SCALER_PATH=models/transformers/scaler.pkl
ENCODERS_PATH=models/transformers/encoders.pkl

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_FILE=subsidy_scoring.log

# ==================== Data Paths ====================
DATA_DIR=data
RESULTS_DIR=results
MODELS_DIR=models
REPORTS_DIR=reports

# ==================== System Settings ====================
TIMEZONE=Asia/Almaty
LANGUAGE=ru
CURRENCY=KZT

# ==================== Email Settings (optional) ====================
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
